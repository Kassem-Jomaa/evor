# ─────────────────────────────────────────────────────────────
# EVOR E-commerce — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (used by the Axios client)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Public site URL (used for absolute links, metadata, SEO)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App display name
NEXT_PUBLIC_APP_NAME=EVOR

# Request timeout for API calls, in milliseconds
NEXT_PUBLIC_API_TIMEOUT=15000
